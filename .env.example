# NASO Delivery Management — Environment Configuration

APP_NAME=NASO
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Local XAMPP example. On live use your real domain, e.g. https://yourdomain.com
# (no trailing slash). Wrong APP_URL = uploaded images won't display.
APP_URL=http://localhost/naso_app/public

# After deploy, also run: php artisan storage:link
# (or rely on /media/{path} routes which work without the symlink)

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=naso_app
DB_USERNAME=root
DB_PASSWORD=

# Broadcasting: log (dev) | redis (with Reverb/Soketi) | pusher
BROADCAST_DRIVER=log

# Cache: file (no Redis) | redis (after installing Redis/Memurai)
CACHE_DRIVER=file

FILESYSTEM_DISK=local

# Queue: sync (dev) | database (Windows) | redis (production)
QUEUE_CONNECTION=database
QUEUE_FALLBACK=database

SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

# Redis — install via scripts/install-redis-windows.ps1
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Laravel Reverb (requires PHP 8.2+) — enable after PHP upgrade
REVERB_APP_ID=naso_app
REVERB_APP_KEY=naso_app_key
REVERB_APP_SECRET=naso_app_secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Dashboard live refresh interval (seconds)
DASHBOARD_REFRESH_INTERVAL=30

# Google Maps — enable Maps JavaScript API, Directions API, and Geocoding API
GOOGLE_MAPS_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
